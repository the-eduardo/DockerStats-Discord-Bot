# Copie para .env e preencha. O .env NÃO deve ser versionado (está no .gitignore).

# Obrigatórios
DISCORD_TOKEN=coloque_o_token_aqui
DISCORD_OWNER_ID=seu_id_numerico_do_discord

# Recomendado: ID do seu servidor privado. Com ele, os slash commands aparecem
# na hora. Sem ele, o registro é global e pode levar até ~1h para propagar.
DISCORD_GUILD_ID=

# Rótulo da máquina exibido no embed
HOSTNAME=Main Machine

# Segundos de espera no shutdown graceful de stop/restart (0 a 300)
SHUTDOWN_TIMEOUT=10

# Caminho para medir uso de disco. No compose montamos o / do host em /host.
DISK_PATH=/host

# --- Dashboard persistente (Fase 2) ---
# Canal inicial do painel (opcional). Você também pode fixar rodando /dashboard
# no canal desejado — a escolha é persistida e sobrevive a restarts.
DASHBOARD_CHANNEL_ID=
# Intervalo de atualização do painel, em segundos (10 a 3600).
REFRESH_SECONDS=60
# Onde persistir a referência do painel (no compose é um volume nomeado).
DATA_DIR=/app/data

# --- Multi-host (Fase 4) ---
# Hosts Docker remotos via SSH. Formato: "key,Label,ssh://user@ip[,/chave]",
# múltiplos separados por ";". Exige openssh-client na imagem (já incluso),
# a chave montada no container e o usuário SSH remoto com sudo sem senha.
# (IPs abaixo são fictícios — faixas reservadas para documentação, RFC 5737.)
#
# Um host:
# Ex.: REMOTE_HOSTS=master,Oracle Master,ssh://ubuntu@203.0.113.10,/root/.ssh/master.key
#
# Vários hosts (separados por ";"):
# Ex.: REMOTE_HOSTS=web,Web VPS,ssh://ubuntu@203.0.113.10,/root/.ssh/web.key;db,DB VPS,ssh://ubuntu@198.51.100.20,/root/.ssh/db.key
REMOTE_HOSTS=
